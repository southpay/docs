{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Documentation",
  "colors": {
    "primary": "#4253FE",
    "light": "#4253FE",
    "dark": "#4253FE"
  },
  "favicon": "/favicon.png",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "icon": "book-open-cover",
          "href": "https://docs.southpay.io"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "pages": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "webhooks"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "pages": [
          {
            "group": "Payments",
            "pages": [
              "api-reference/payments"
            ]
          },
          {
            "group": "Stores",
            "pages": [
              "api-reference/stores"
            ]
          },
          {
            "group": "Balances & Assets",
            "pages": [
              "api-reference/assets"
            ]
          },
          {
            "group": "Payouts",
            "pages": [
              "api-reference/payout-schedules",
              "api-reference/payouts",
              "api-reference/payout-details"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "api-reference/webhook-endpoints"
            ]
          },
          {
            "group": "White Label",
            "pages": [
              "api-reference/custom-domains"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png",
    "href": "https://docs.southpay.io"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@southpay.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://api.southpay.io"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/southpay",
      "linkedin": "https://linkedin.com/company/southpay"
    }
  },
  "appearance": {
    "strict": true,
    "default": "light"
  },
  "thumbnails": {
    "appearance": "light"
  },
  "banner": {
    "content": "SouthPay Documentation",
    "dismissible": false
  }
}