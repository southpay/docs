{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "SouthPay",
  "colors": {
    "primary": "#4253FE",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "icon": "book-open-cover",
          "href": "https://docs.southpay.io"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": []
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png",
    "href": "https://southpay.io"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@southpay.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://api.southpay.io"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/southpay",
      "linkedin": "https://linkedin.com/company/southpay"
    }
  },
  "appearance": {
    "strict": true,
    "default": "light"
  }
}
